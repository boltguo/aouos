---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/home/Nav.astro';
import { ArrowLeft, Calendar } from '@lucide/astro';
import { getEntry, getCollection, render } from 'astro:content';

const { slug } = Astro.params;
const post = slug ? await getEntry('blog', slug) : null;

if (!post) {
  throw new Error(`Blog post not found for slug: ${slug}`);
}

const { Content } = await render(post);
const data = post.data;
const formatDate = (value: Date) =>
  value.toLocaleDateString('en-US', {
    month: 'short',
    day: '2-digit',
    year: 'numeric',
  });

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map((entry) => ({
    params: { slug: entry.id },
  }));
}
---

<Layout title={data.title} description={data.description}>
  <div
    class="bg-background-light relative min-h-screen overflow-x-hidden text-gray-900 transition-colors duration-300"
  >
    <Nav />

    <article class="relative z-10 pt-24 pb-40 lg:pt-30">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <!-- Back link -->
        <a
          class="hover:text-primary mb-10 inline-flex items-center text-sm font-medium text-gray-700 transition-colors duration-200"
          href="/blog"
        >
          <ArrowLeft class="mr-2 h-4 w-4" />
          Back to blog
        </a>

        <!-- Header -->
        <header class="mb-10">
          <div class="mb-5 flex items-center gap-2 text-gray-400">
            <Calendar class="h-3.5 w-3.5" />
            <time class="font-mono text-xs tracking-wide"
              >{formatDate(data.date)}</time
            >
          </div>
          <h1
            class="mb-5 text-3xl leading-snug font-bold tracking-tight text-gray-900 sm:text-4xl sm:leading-snug lg:text-[2.75rem] lg:leading-snug"
          >
            {data.title}
          </h1>
          <p class="text-base leading-relaxed text-gray-500 sm:text-lg">
            {data.description}
          </p>
        </header>

        <!-- Cover image -->
        {
          data.cover && (
            <div class="mb-12 overflow-hidden rounded-lg border border-gray-100">
              <img
                src={data.cover}
                alt={data.title}
                class="h-auto w-full object-cover"
                loading="eager"
                onerror="this.parentElement.style.display='none'"
              />
            </div>
          )
        }

        <!-- Divider -->
        <div class="mb-12 h-px bg-gray-200"></div>

        <!-- Article body -->
        <div class="prose prose-aouos prose-lg max-w-none">
          <Content />
        </div>
      </div>
    </article>

    <!-- Scroll to top button -->
    <button
      id="scroll-to-top"
      class="fixed right-6 bottom-8 z-50 flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border border-gray-200 bg-white shadow-md transition-all duration-300 hover:bg-gray-50 hover:shadow-lg"
      style="opacity: 0; transform: translateY(10px); pointer-events: none;"
      aria-label="Scroll to top"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-gray-500"><path d="m18 15-6-6-6 6"></path></svg
      >
    </button>
  </div>
</Layout>

<script>
  const btn = document.getElementById('scroll-to-top');
  if (btn) {
    let visible = false;
    window.addEventListener('scroll', () => {
      const shouldShow = window.scrollY > 300;
      if (shouldShow !== visible) {
        visible = shouldShow;
        btn.style.opacity = visible ? '1' : '0';
        btn.style.transform = visible ? 'translateY(0)' : 'translateY(10px)';
        btn.style.pointerEvents = visible ? 'auto' : 'none';
      }
    });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
