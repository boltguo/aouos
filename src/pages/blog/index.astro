---
import Layout from '../../layouts/Layout.astro';
import HomeFooter from '../../components/home/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const formatDate = (value: Date) =>
  value.toLocaleDateString('en-US', {
    month: 'short',
    day: '2-digit',
    year: 'numeric',
  });
---

<Layout
  title="Blog — BoltGuo"
  description="Thoughts and notes from BoltGuo on frontend engineering and AI."
>
  <div class="min-h-screen bg-white text-[var(--ink)]">
    <main class="viz-main">
      <section class="viz-hero-band">
        <div class="viz-glow" aria-hidden="true"></div>
        <div class="viz-dot-grid" aria-hidden="true"></div>
        <div class="relative mx-auto max-w-4xl px-6 py-16 lg:py-20">
          <p class="viz-kicker">AOUOS</p>
          <h1 class="mt-2 text-4xl font-semibold text-[var(--ink)] sm:text-5xl">
            Blog
          </h1>
          <p class="viz-muted mt-5 max-w-2xl text-base leading-7">
            Notes on frontend engineering, AI workflows, and personal
            infrastructure.
          </p>
        </div>
      </section>

      <section class="mx-auto max-w-4xl px-6 py-12 lg:py-16">
        <h2 class="viz-kicker mb-6">All posts</h2>
        <ul class="flex flex-col gap-6">
          {
            posts.map((post) => (
              <li>
                <a class="viz-blog-card group" href={`/blog/${post.id}`}>
                  <canvas
                    class="rough-frame-canvas"
                    data-rough-frame
                    aria-hidden="true"
                  />
                  <div class="relative flex flex-col gap-5 p-5 sm:flex-row sm:items-center sm:gap-8 sm:p-7">
                    <div class="shrink-0 sm:w-[42%] sm:max-w-[300px]">
                      <canvas
                        class="sketch-canvas"
                        data-sketch="blog"
                        data-slug={post.id}
                        width="320"
                        height="180"
                        aria-label={`${post.data.title} sketch`}
                      />
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 text-sm text-[rgba(74,65,56,0.82)]">
                        <span class="viz-chip">AOUOS</span>
                        <span>{formatDate(post.data.date)}</span>
                      </div>
                      <h2 class="mt-2.5 text-xl font-semibold text-[var(--ink)] transition-colors group-hover:text-[#2563eb] sm:text-2xl">
                        {post.data.title}
                      </h2>
                      <p class="mt-2 text-base leading-relaxed text-[rgba(74,65,56,0.82)]">
                        {post.data.description}
                      </p>
                    </div>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <HomeFooter />
    </main>
  </div>
</Layout>
