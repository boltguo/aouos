---
import Icon from '../Icon.astro';
import { projects, socials } from '../../data/projects';

const columns = [
  { title: 'Websites', kind: 'website' },
  { title: 'Apps & tools', kind: 'tool' },
  { title: 'Extensions', kind: 'extension' },
]
  .map((column) => ({
    ...column,
    items: projects.filter((p) => p.kind === column.kind),
  }))
  .filter((column) => column.items.length > 0);

const columnTitle =
  'text-[11px] font-semibold text-[rgba(74,65,56,0.82)] uppercase';
const columnLink =
  'text-sm text-[var(--ink)] no-underline transition-colors hover:text-[#2563eb]';
---

<footer class="border-t border-black/5">
  <div class="mx-auto max-w-7xl px-6 py-20">
    <div
      class:list={[
        'grid grid-cols-2 gap-x-8 gap-y-12 md:gap-x-10',
        columns.length >= 3
          ? 'md:grid-cols-[9fr_5fr_5fr_5fr]'
          : 'md:grid-cols-[9fr_5fr_5fr]',
      ]}
    >
      <div class="col-span-2 md:col-span-1">
        <a
          class="inline-flex items-center gap-2 no-underline"
          href="/"
          aria-label="AOUOS"
        >
          <img src="/logo.svg" alt="" width="26" height="26" />
          <span
            class="font-canvas text-[1.25rem] font-semibold text-[var(--ink)] transition-colors hover:text-[#2563eb]"
          >
            AOUOS
          </span>
        </a>
        <p class="mt-3 text-sm leading-6 text-[rgba(74,65,56,0.82)]">
          Bolt Guo's projects, tools, and small product experiments — it's
          boltguo pretty much everywhere.
        </p>
        <div class="mt-3 -ml-3 flex items-center gap-1">
          {
            socials.map(({ name, icon, href }) => (
              <a
                class="inline-flex h-11 w-11 items-center justify-center rounded-md text-[var(--ink)] transition-colors hover:bg-slate-100 hover:text-[#2563eb]"
                href={href}
                target="_blank"
                rel="noreferrer"
                aria-label={name}
              >
                <Icon name={icon} size={24} />
              </a>
            ))
          }
        </div>
      </div>

      {
        columns.map(({ title, items }) => (
          <div class="flex flex-col gap-3">
            <span class={columnTitle}>{title}</span>
            {items.map((item) => (
              <a
                class={columnLink}
                href={item.link}
                target="_blank"
                rel="noreferrer"
              >
                {item.title}
              </a>
            ))}
          </div>
        ))
      }
    </div>

    <p
      class="font-canvas mt-14 border-t border-black/5 pt-6 text-sm text-[rgba(74,65,56,0.78)]"
    >
      © 2026 AOUOS · drawn and coded by Bolt Guo
    </p>
  </div>
</footer>
