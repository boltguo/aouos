---
interface BlogCard {
  slug: string;
  title: string;
  description: string;
  date: Date;
}

const { posts = [] } = Astro.props as { posts?: BlogCard[] };

const formatDate = (value: Date) =>
  value.toLocaleDateString('en-US', {
    month: 'short',
    day: '2-digit',
    year: 'numeric',
  });
---

<section class="mx-auto max-w-5xl px-6 py-14 lg:py-20" id="blog">
  {
    posts.length === 0 ? (
      <p class="viz-muted">No posts yet.</p>
    ) : (
      <>
        <canvas
          class="viz-divider"
          data-sketch="divider"
          data-roughness="2.4"
          data-bowing="4"
          width="900"
          height="40"
          aria-hidden="true"
        />
        <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
          <h2 class="viz-kicker">Latest notes</h2>
          <a class="aouos-text-link" href="/blog">
            View all notes →
          </a>
        </div>
        <ul class="flex flex-col gap-6">
          {posts.map((post) => (
            <li>
              <a class="viz-blog-card group" href={`/blog/${post.slug}`}>
                <canvas
                  class="rough-frame-canvas"
                  data-rough-frame
                  aria-hidden="true"
                />
                <div class="relative flex flex-col gap-5 p-5 sm:flex-row sm:items-center sm:gap-8 sm:p-7">
                  <div class="shrink-0 sm:w-[42%] sm:max-w-[300px]">
                    <canvas
                      class="sketch-canvas"
                      data-sketch="blog"
                      data-slug={post.slug}
                      width="320"
                      height="180"
                      aria-label={`${post.title} sketch`}
                    />
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 text-sm text-[rgba(74,65,56,0.62)]">
                      <span class="viz-chip">AOUOS</span>
                      <span>{formatDate(post.date)}</span>
                    </div>
                    <h3 class="mt-2.5 text-xl font-semibold text-[var(--ink)] transition-colors group-hover:text-[#2563eb] sm:text-2xl">
                      {post.title}
                    </h3>
                    <p class="mt-2 text-base leading-relaxed text-[rgba(74,65,56,0.68)]">
                      {post.description}
                    </p>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </>
    )
  }
</section>
