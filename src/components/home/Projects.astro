---
import { projects } from '../../data/projects';

const HOME_PROJECT_IDS = ['01', '05', '06', '07'];

const homeProjects = HOME_PROJECT_IDS.map(
  (id) => projects.find((p) => p.id === id)!
);
---

<section
  class="border-border-light bg-background-light relative border-b py-24"
  id="projects"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div
      class="mb-16 flex flex-col items-start justify-between md:flex-row md:items-center"
    >
      <div>
        <span class="mb-2 block font-mono text-xs text-gray-400">01</span>
        <h2 class="text-3xl font-bold text-gray-900">Selected Projects</h2>
      </div>
      <p class="mt-4 max-w-md text-sm text-gray-600">
        A curated collection of digital tools and personal works, ranging from
        focused productivity utilities to experimental web applications.
      </p>
    </div>
    <div
      class="grid grid-cols-1 gap-0 divide-y divide-gray-200 border-t border-b border-gray-200 md:grid-cols-2 md:divide-x md:divide-y-0 lg:grid-cols-4"
    >
      {
        homeProjects.map(
          ({ id, title, description, tech, Icon, link }, index) => (
            <a
              href={link}
              target="_blank"
              rel="noreferrer"
              class="group relative p-8 transition-colors duration-300 hover:bg-white"
            >
              <div class="plus-marker absolute -top-[6px] -left-[6px] z-20" />
              {index === homeProjects.length - 1 && (
                <div class="plus-marker absolute -top-[6px] -right-[6px] z-20" />
              )}
              <div class="mb-6 flex items-start justify-between">
                <span class="font-mono text-xs text-gray-400">{id}</span>
                <Icon class="h-5 w-5 text-gray-400 transition-colors" />
              </div>
              <h3 class="mb-3 text-lg font-bold text-gray-900">{title}</h3>
              <p class="mb-12 text-sm leading-relaxed text-gray-500">
                {description}
              </p>
              <div class="absolute bottom-8 left-8 space-y-1 font-mono text-[10px] tracking-wider text-gray-400 uppercase">
                {tech.map((item) => (
                  <div class="block">{item}</div>
                ))}
              </div>
            </a>
          )
        )
      }
    </div>
  </div>
</section>
