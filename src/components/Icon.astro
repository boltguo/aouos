---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  style="overflow: visible"
  aria-hidden="true"
>
  <g
    fill="none"
    stroke="currentColor"
    stroke-width={icon.strokeWidth ?? 2.2}
    stroke-linecap="round"
    stroke-linejoin="round"
    filter="url(#rough-ink)"
  >
    {icon.paths.map((d) => <path d={d} />)}
  </g>
</svg>
