---
import Layout from '../../layouts/Layout.astro';
import HomeFooter from '../../components/home/Footer.astro';
import { projects } from '../../data/projects';

const TILE_ROTATION = [1.1, -1.3, 0.9, -0.9, 1.2, -1.1, 0.8];
const BEAT_ACCENT = [
  '#0891B2',
  '#7C3AED',
  '#CA8A04',
  '#0284C7',
  '#BE185D',
  '#0891B2',
  '#7C3AED',
];
---

<Layout
  title="Projects — BoltGuo"
  description="Project work by BoltGuo: web, AI, dashboards, learning maps, and tooling."
>
  <div class="paper-page text-[var(--ink)]">
    <main class="viz-main">
      <section class="viz-hero">
        <h1
          class="font-canvas text-[clamp(2.25rem,5vw,3.5rem)] leading-[1.05] text-[var(--ink)]"
        >
          Projects
        </h1>
        <p
          class="viz-muted mx-auto mt-5 max-w-2xl text-base leading-relaxed md:text-lg"
        >
          AOUOS projects shown in the same feature-row rhythm as VizLearn:
          sketch, short explanation, and enough room to scan each idea.
        </p>
      </section>

      <section class="viz-feature-section">
        <ul class="viz-feature-list">
          {
            projects.map((project, index) => {
              const flip = index % 2 === 1;
              return (
                <li>
                  <a
                    class="viz-feature-row viz-feature-link"
                    href={project.link}
                    target="_blank"
                    rel="noreferrer"
                  >
                    <div class={`viz-feature-art ${flip ? 'viz-order-2' : ''}`}>
                      <span
                        aria-hidden="true"
                        class="viz-beat-number"
                        style={`color: ${BEAT_ACCENT[index]}`}
                      >
                        {String(index + 1).padStart(2, '0')}
                      </span>
                      <div
                        class="viz-sketch-pad"
                        style={`rotate: ${TILE_ROTATION[index]}deg`}
                      >
                        <canvas
                          class="sketch-canvas"
                          data-sketch="project"
                          data-project={project.id}
                          width="480"
                          height="260"
                          aria-label={`${project.title} sketch`}
                        />
                      </div>
                    </div>
                    <div>
                      <h2 class="viz-feature-title">{project.title}</h2>
                      <p class="viz-feature-desc">{project.description}</p>
                    </div>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </section>

      <HomeFooter />
    </main>
  </div>
</Layout>
