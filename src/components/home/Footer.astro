---
import { Mail, Newspaper, Shapes } from '@lucide/astro';
import GitHubIcon from '../GitHubIcon.astro';
---

<footer class="border-t border-black/5">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div
      class="grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-4 md:grid-cols-[9fr_5fr_5fr_5fr] md:gap-x-10"
    >
      <div class="col-span-2 sm:col-span-4 md:col-span-1">
        <a
          class="inline-flex items-center gap-2 no-underline"
          href="/"
          aria-label="AOUOS"
        >
          <img src="/logo.svg" alt="" width="26" height="26" />
          <span
            class="font-canvas text-[1.25rem] font-semibold text-[var(--ink)] transition-colors hover:text-[#2563eb]"
          >
            AOUOS
          </span>
        </a>
        <p class="mt-3 text-sm leading-6 text-[rgba(74,65,56,0.82)]">
          Bolt Guo's projects, notes, and small product experiments.
        </p>
        <div class="mt-5 flex items-center gap-4">
          <a
            class="inline-flex items-center justify-center text-[var(--ink)] transition-colors hover:text-[#2563eb]"
            href="https://github.com/boltguo"
            target="_blank"
            rel="noreferrer"
            aria-label="GitHub"
          >
            <GitHubIcon class="h-[18px] w-[18px]" />
          </a>
          <a
            class="inline-flex items-center justify-center text-[var(--ink)] transition-colors hover:text-[#2563eb]"
            href="mailto:hello@aouos.com"
            aria-label="Email"
          >
            <Mail size={18} stroke-width={2} />
          </a>
        </div>
      </div>

      <div class="flex flex-col gap-3">
        <span
          class="text-[11px] font-semibold text-[rgba(74,65,56,0.82)] uppercase"
        >
          Product
        </span>
        <a
          class="inline-flex items-center gap-2.5 text-sm text-[var(--ink)] no-underline transition-colors hover:text-[#2563eb]"
          href="/projects"
        >
          <Shapes size={16} stroke-width={2} aria-hidden="true" />
          Projects
        </a>
        <a
          class="inline-flex items-center gap-2.5 text-sm text-[var(--ink)] no-underline transition-colors hover:text-[#2563eb]"
          href="/blog"
        >
          <Newspaper size={16} stroke-width={2} aria-hidden="true" />
          Blog
        </a>
      </div>

      <div class="flex flex-col gap-3">
        <span
          class="text-[11px] font-semibold text-[rgba(74,65,56,0.82)] uppercase"
        >
          Work
        </span>
        <a
          class="text-sm text-[var(--ink)] no-underline transition-colors hover:text-[#2563eb]"
          href="https://vizlearn.app/"
          target="_blank"
          rel="noreferrer"
        >
          VizLearn
        </a>
        <a
          class="text-sm text-[var(--ink)] no-underline transition-colors hover:text-[#2563eb]"
          href="https://aouoai.com/"
          target="_blank"
          rel="noreferrer"
        >
          AouoAI
        </a>
        <a
          class="text-sm text-[var(--ink)] no-underline transition-colors hover:text-[#2563eb]"
          href="https://wmremover.aouos.com/"
          target="_blank"
          rel="noreferrer"
        >
          Watermark Remover
        </a>
      </div>

      <div class="flex flex-col gap-3">
        <span
          class="text-[11px] font-semibold text-[rgba(74,65,56,0.82)] uppercase"
        >
          Connect
        </span>
        <a
          class="text-sm text-[var(--ink)] no-underline transition-colors hover:text-[#2563eb]"
          href="mailto:hello@aouos.com"
        >
          hello@aouos.com
        </a>
      </div>
    </div>
  </div>
</footer>
