---
import { Newspaper, Shapes } from '@lucide/astro';
---

<header
  class="nav-surface sticky top-0 z-50 flex h-14 shrink-0 items-center border-b backdrop-blur"
>
  <div
    class="relative mx-auto flex w-full max-w-7xl items-center justify-between px-6"
  >
    <a
      class="z-10 flex items-center gap-2 no-underline"
      href="/"
      aria-label="AOUOS"
    >
      <img src="/logo.svg" alt="" width="26" height="26" />
      <span
        class="font-canvas hidden text-[1.4rem] leading-none font-semibold text-[var(--ink)] sm:inline"
      >
        AOUOS
      </span>
    </a>

    <nav
      aria-label="Primary navigation"
      class="absolute left-1/2 flex -translate-x-1/2 items-center gap-0.5"
    >
      <a
        href="/projects"
        class="inline-flex items-center gap-1.5 rounded-md px-2 py-1.5 text-sm font-semibold whitespace-nowrap text-[rgba(74,65,56,0.65)] no-underline transition-colors hover:bg-slate-100 hover:text-[var(--ink)] sm:px-2.5"
      >
        <Shapes size={16} strokeWidth={1.9} />
        <span class="hidden sm:inline">Projects</span>
      </a>
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 rounded-md px-2 py-1.5 text-sm font-semibold whitespace-nowrap text-[rgba(74,65,56,0.65)] no-underline transition-colors hover:bg-slate-100 hover:text-[var(--ink)] sm:px-2.5"
      >
        <Newspaper size={16} strokeWidth={1.9} />
        <span class="hidden sm:inline">Blog</span>
      </a>
    </nav>

    <a
      class="z-10 inline-flex h-9 w-9 items-center justify-center rounded-md text-[rgba(74,65,56,0.65)] transition-colors hover:bg-slate-100 hover:text-[var(--ink)]"
      href="https://github.com/boltguo"
      target="_blank"
      rel="noreferrer"
      title="GitHub"
      aria-label="GitHub"
    >
      <svg
        class="h-[17px] w-[17px]"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.595 24 12.297c0-6.627-5.373-12-12-12"
        ></path>
      </svg>
    </a>
  </div>
</header>
