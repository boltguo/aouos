---
import Icon from '../Icon.astro';
import HeroAnya from './HeroAnya.astro';
import HeroMiku from './HeroMiku.astro';
---

<section class="aouos-hero">
  {/* quiet hand-drawn marks scattered around the hero */}
  <svg
    class="hero-doodle hero-doodle--arc-pair"
    width="42"
    height="20"
    viewBox="0 0 42 20"
    aria-hidden="true"
  >
    <g
      fill="none"
      stroke="#d5d0ff"
      stroke-width="2.3"
      stroke-linecap="round"
      filter="url(#rough-ink)"
    >
      <path d="M3 4 C 12 7, 20 14, 39 15"></path>
      <path d="M4 7 C 14 11, 23 17, 38 17" opacity="0.58"></path>
    </g>
  </svg>
  <svg
    class="hero-doodle hero-doodle--wonky-rect"
    width="24"
    height="30"
    viewBox="0 0 24 30"
    aria-hidden="true"
  >
    <path
      d="M6 4 L18 2 L22 25 L8 28 Z"
      fill="none"
      stroke="#d8d3ff"
      stroke-width="2.4"
      stroke-linecap="round"
      stroke-linejoin="round"
      filter="url(#rough-ink)"></path>
  </svg>
  <svg
    class="hero-doodle hero-doodle--bean"
    width="18"
    height="18"
    viewBox="0 0 18 18"
    aria-hidden="true"
  >
    <path
      d="M4 11 C2 7, 4 3, 8 2 C13 1, 17 5, 16 10 C15 15, 11 17, 7 16 C5 15, 4 13, 4 11 Z"
      fill="#bff1c8"
      filter="url(#rough-ink)"></path>
  </svg>
  <svg
    class="hero-doodle hero-doodle--ring"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path
      d="M12 3 C 18 3, 21 8, 20 13 C 19 19, 12 22, 8 19 C 3 16, 3 8, 8 5 C 10 3.6, 12 3, 13 4"
      fill="none"
      stroke="#ffd6ad"
      stroke-width="2.4"
      stroke-linecap="round"
      filter="url(#rough-ink)"></path>
  </svg>
  <svg
    class="hero-doodle hero-doodle--smile"
    width="34"
    height="18"
    viewBox="0 0 34 18"
    aria-hidden="true"
  >
    <path
      d="M2 4 C 10 15, 23 16, 32 4"
      fill="none"
      stroke="#ffd2a8"
      stroke-width="2.5"
      stroke-linecap="round"
      filter="url(#rough-ink)"></path>
  </svg>
  <svg
    class="hero-doodle hero-doodle--zigzag"
    width="42"
    height="20"
    viewBox="0 0 42 20"
    aria-hidden="true"
  >
    <path
      d="M2 14 C 9 10, 11 18, 17 13 L21 5 L27 15 L33 4 L40 8"
      fill="none"
      stroke="#d2cdff"
      stroke-width="2.4"
      stroke-linecap="round"
      stroke-linejoin="round"
      filter="url(#rough-ink)"></path>
  </svg>
  <svg
    class="hero-doodle hero-doodle--blue-stroke"
    width="34"
    height="16"
    viewBox="0 0 34 16"
    aria-hidden="true"
  >
    <path
      d="M2 3 Q 14 6, 31 14"
      fill="none"
      stroke="#bce2fb"
      stroke-width="2.8"
      stroke-linecap="round"
      filter="url(#rough-ink)"></path>
  </svg>
  <svg
    class="hero-doodle hero-doodle--coral-ring"
    width="17"
    height="17"
    viewBox="0 0 18 18"
    aria-hidden="true"
  >
    <path
      d="M9 2 C13 2, 16 5, 16 9 C16 13, 13 16, 9 16 C5 16, 2 13, 2 9 C2 5, 5 2, 9 2 Z"
      fill="none"
      stroke="#ffc2bd"
      stroke-width="2.4"
      stroke-linecap="round"
      filter="url(#rough-ink)"></path>
  </svg>

  <div class="hero-motion-top">
    <canvas
      class="sketch-canvas"
      data-hero-motion="top"
      width="760"
      height="190"
      role="img"
      aria-label="Hand-drawn music notes and a pulsing equalizer"></canvas>
    <div class="hero-miku">
      <HeroMiku />
    </div>
  </div>

  <div class="aouos-hero-copy">
    <h1 class="aouos-hero-title">
      <span class="hero-hello">Hello, I'm</span><span class="hero-name"
        >Bolt Guo.<svg
          class="hero-name-swash"
          viewBox="0 0 220 24"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <path
            d="M6 14 C 42 5, 80 20, 116 11 S 186 9, 214 14"
            fill="none"
            stroke="var(--canvas-blue)"
            stroke-width="7"
            stroke-linecap="round"
            filter="url(#rough-ink)"></path>
        </svg>
      </span>
    </h1>
    <p class="viz-muted hero-intro">
      I'm a frontend developer. I build tools that help me learn or solve a
      problem, and I usually handle the design and code myself.
    </p>
    <p class="viz-muted hero-intro hero-intro--aside">
      Away from the keyboard, I'm playing games, watching anime, or making an
      already-long playlist even longer.
    </p>

    <div class="hero-tags">
      <span class="project-tag">Frontend</span>
      <span class="project-tag">Learning tools</span>
      <span class="project-tag">Indie products</span>
    </div>

    <div class="hero-cta">
      <a class="band-btn band-btn--primary" href="#projects">
        See my work
        <Icon name="arrow-down" size={17} />
      </a>
      <a class="band-btn" href="#story">How I build</a>
    </div>
  </div>

  <div class="hero-sketch-pad">
    <canvas
      class="sketch-canvas"
      data-hero-motion="bottom"
      width="760"
      height="230"
      role="img"
      aria-label="Hand-drawn wired game controller with colorful buttons"
    ></canvas>
    <div class="hero-anya">
      <HeroAnya />
    </div>
  </div>

  <a class="hero-scroll-cue" href="#story" aria-label="Jump to how I build">
    <span>scroll</span>
    <svg width="16" height="30" viewBox="0 0 16 30" aria-hidden="true">
      <g
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M8 2 C 5 7, 11 11, 8 16 L 8 22"></path>
        <path d="M3 21 L 8 28 L 13 21"></path>
      </g>
    </svg>
  </a>
</section>

<script>
  import '../../scripts/hero-motion';
</script>
