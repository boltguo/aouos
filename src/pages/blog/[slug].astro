---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/home/Nav.astro';
import HomeFooter from '../../components/home/Footer.astro';
import { getEntry, getCollection, render } from 'astro:content';

const { slug } = Astro.params;
const post = slug ? await getEntry('blog', slug) : null;

if (!post) {
  throw new Error(`Blog post not found for slug: ${slug}`);
}

const { Content } = await render(post);
const data = post.data;
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const currentIndex = posts.findIndex((entry) => entry.id === post.id);
const olderPost =
  currentIndex >= 0 && currentIndex < posts.length - 1
    ? posts[currentIndex + 1]
    : null;
const newerPost = currentIndex > 0 ? posts[currentIndex - 1] : null;

const formatDate = (value: Date) =>
  value.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  });

const estimateReadingMinutes = (body = '') => {
  const text = body.replace(/```[\s\S]*?```/g, ' ');
  const cjkCount = text.match(/[\u4e00-\u9fff]/gu)?.length ?? 0;
  const latinWordCount =
    text
      .replace(/[\u4e00-\u9fff]/gu, ' ')
      .match(/[A-Za-z0-9_]+(?:[-'][A-Za-z0-9_]+)*/g)?.length ?? 0;

  return Math.max(1, Math.ceil((latinWordCount + cjkCount / 2) / 220));
};

const readingMinutes = estimateReadingMinutes(post.body);

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map((entry) => ({
    params: { slug: entry.id },
  }));
}
---

<Layout title={data.title} description={data.description}>
  <div class="article-reading-page">
    <Nav />

    <div class="viz-main">
      <article>
        <section class="viz-article-hero">
          <div class="viz-article-glow" aria-hidden="true"></div>
          <div class="viz-article-dots" aria-hidden="true"></div>

          <div class="viz-article-hero-inner">
            <a
              class="viz-article-back"
              href="/blog"
              aria-label="Back to all posts"
            >
              ← All posts
            </a>

            <div class="viz-article-hero-grid">
              <header class="viz-article-header">
                <p class="viz-article-category">AOUOS</p>
                <h1 class="viz-article-title">{data.title}</h1>
                <p class="viz-article-description">{data.description}</p>
                <div class="viz-article-meta">
                  <time datetime={data.date.toISOString()}
                    >{formatDate(data.date)}</time
                  >
                  <span aria-hidden="true">·</span>
                  <span>{readingMinutes} min read</span>
                </div>
              </header>

              <div class="viz-article-art" aria-hidden="true">
                <canvas
                  class="sketch-canvas"
                  data-sketch="blog"
                  data-slug={post.id}
                  width="320"
                  height="180"></canvas>
              </div>
            </div>
          </div>
        </section>

        <section class="viz-article-content">
          {
            data.cover && (
              <div class="viz-article-cover">
                <img
                  src={data.cover}
                  alt={data.title}
                  class="h-auto w-full object-cover"
                  loading="eager"
                  onerror="this.parentElement.style.display='none'"
                />
              </div>
            )
          }

          <div class="viz-article-body">
            <Content />
          </div>

          <nav class="viz-series-nav" aria-label="Continue the series">
            <p class="viz-kicker">Continue the series</p>
            <div class="viz-series-grid">
              {
                olderPost && (
                  <a class="viz-series-link" href={`/blog/${olderPost.id}`}>
                    <span>Previous</span>
                    <strong>{olderPost.data.title}</strong>
                  </a>
                )
              }
              {
                newerPost && (
                  <a
                    class="viz-series-link next"
                    href={`/blog/${newerPost.id}`}
                  >
                    <span>Next</span>
                    <strong>{newerPost.data.title}</strong>
                  </a>
                )
              }
            </div>
          </nav>
        </section>
      </article>

      <HomeFooter />
    </div>

    <button
      id="scroll-to-top"
      class="viz-scroll-top"
      style="opacity: 0; transform: translateY(10px); pointer-events: none;"
      aria-label="Scroll to top"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"><path d="m18 15-6-6-6 6"></path></svg
      >
    </button>
  </div>
</Layout>

<script>
  const btn = document.getElementById('scroll-to-top');
  if (btn) {
    let visible = false;
    window.addEventListener('scroll', () => {
      const shouldShow = window.scrollY > 300;
      if (shouldShow !== visible) {
        visible = shouldShow;
        btn.style.opacity = visible ? '1' : '0';
        btn.style.transform = visible ? 'translateY(0)' : 'translateY(10px)';
        btn.style.pointerEvents = visible ? 'auto' : 'none';
      }
    });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
