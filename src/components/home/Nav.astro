---
import { Newspaper, Shapes } from '@lucide/astro';
import GitHubIcon from '../GitHubIcon.astro';
---

<header
  class="nav-surface sticky top-0 z-50 flex h-14 shrink-0 items-center border-b backdrop-blur"
>
  <div
    class="relative mx-auto flex w-full max-w-7xl items-center justify-between px-6"
  >
    <a
      class="z-10 flex items-center gap-2 no-underline"
      href="/"
      aria-label="AOUOS"
    >
      <img src="/logo.svg" alt="" width="26" height="26" />
      <span
        class="font-canvas hidden text-[1.4rem] leading-none font-semibold text-[var(--ink)] sm:inline"
      >
        AOUOS
      </span>
    </a>

    <nav
      aria-label="Primary navigation"
      class="absolute left-1/2 flex -translate-x-1/2 items-center gap-0.5"
    >
      <a
        href="/projects"
        class="inline-flex items-center gap-1.5 rounded-md px-2 py-1.5 text-sm font-semibold whitespace-nowrap text-[rgba(74,65,56,0.82)] no-underline transition-colors hover:bg-slate-100 hover:text-[var(--ink)] sm:px-2.5"
      >
        <Shapes size={16} stroke-width={1.9} />
        <span class="hidden sm:inline">Projects</span>
      </a>
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 rounded-md px-2 py-1.5 text-sm font-semibold whitespace-nowrap text-[rgba(74,65,56,0.82)] no-underline transition-colors hover:bg-slate-100 hover:text-[var(--ink)] sm:px-2.5"
      >
        <Newspaper size={16} stroke-width={1.9} />
        <span class="hidden sm:inline">Blog</span>
      </a>
    </nav>

    <a
      class="z-10 inline-flex h-9 w-9 items-center justify-center rounded-md text-[rgba(74,65,56,0.82)] transition-colors hover:bg-slate-100 hover:text-[var(--ink)]"
      href="https://github.com/boltguo"
      target="_blank"
      rel="noreferrer"
      title="GitHub"
      aria-label="GitHub"
    >
      <GitHubIcon class="h-[17px] w-[17px]" />
    </a>
  </div>
</header>
