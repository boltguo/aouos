---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import BrushBand from '../components/home/BrushBand.astro';
import StoryBlock from '../components/home/StoryBlock.astro';
import Projects from '../components/home/Projects.astro';
import HomeFooter from '../components/home/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
---

<Layout
  title="Bolt Guo — Frontend Developer & AI Tool Builder"
  description="A hand-drawn personal site for Bolt Guo's frontend projects, AI tools, and web experiments."
>
  <div class="paper-page text-[var(--ink)]">
    <main class="viz-main">
      <Hero />

      {/* --- Chapter 1: origin --------------------------------------- */}
      <BrushBand
        color="var(--canvas-blue)"
        title="How I Work"
        outline="#1f1b16"
        id="story"
      />

      <StoryBlock
        eyebrow="How I learn"
        title="I don't take notes. I build them."
        sketch="learn"
        accent="var(--canvas-blue)"
      >
        <p>
          Docs and courses never stick with me. So when I wanted algorithms to
          finally make sense, I built VizLearn — visual lessons for arrays,
          trees, and graphs. My React 19 and Vue 3 "notes" turned into full
          learning systems with dozens of lessons and real URLs.
        </p>
        <p>If I can't build it, I don't really know it yet.</p>
      </StoryBlock>

      <StoryBlock
        eyebrow="What I ship"
        title="Small tools that scratch real itches."
        sketch="ship"
        flip
        accent="var(--canvas-lilac)"
      >
        <p>
          Most of my projects start as a daily annoyance. Wondering where my AI
          tokens went became AouoAI, a chart-driven usage notebook. Watermarks
          on generated images became a little Vue tool that strips them locally.
        </p>
        <p>
          Nothing here is a startup pitch — just problems I had, solved in
          public.
        </p>
      </StoryBlock>

      {/* --- Chapter 2: the work ------------------------------------- */}
      <BrushBand
        color="var(--canvas-lilac)"
        title="Things I've Built"
        outline="#1f1b16"
        id="projects"
      />

      <Projects />

      {/* --- Chapter 3: contact -------------------------------------- */}
      <BrushBand color="#7b8cff" title="Say Hi!" outline="#1f1b16" id="contact">
        <div class="band-cta">
          <a class="band-btn" href="mailto:hello@aouos.com">hello@aouos.com</a>
        </div>
      </BrushBand>

      <HomeFooter />
      <BackToTop />
    </main>
  </div>
</Layout>
