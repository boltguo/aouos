---
import Icon from '../Icon.astro';
import { projects } from '../../data/projects';

const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured && !p.footerOnly);

const TILE_ROTATION = [1.1, -1.3];
const FEATURED_ACCENT = ['#0891B2', '#B83A2D'];
const MINI_ACCENT = ['#CA8A04', '#DB2777', '#059669', '#DC2626', '#2563EB'];
---

<section class="viz-feature-section">
  <div class="mb-14 max-w-2xl">
    <p class="viz-kicker">Projects</p>
    <h2 class="viz-feature-heading">Two projects I'd show you first.</h2>
  </div>

  <ul class="project-cards">
    {
      featured.map(({ id, title, description, tech, link, proof }, index) => {
        const flip = index % 2 === 1;
        const accent = FEATURED_ACCENT[index % FEATURED_ACCENT.length];
        return (
          <li class="project-card" style={`--card-accent:${accent}`}>
            <div class={`project-card__row ${flip ? 'is-flip' : ''}`}>
              <div class="project-card__info">
                <div class="project-card__tags">
                  {tech.map((t) => (
                    <span class="project-tag">{t}</span>
                  ))}
                </div>
                <h3 class="project-card__title">{title}</h3>
                <p class="project-card__desc">{description}</p>
                {proof && <p class="project-card__proof">{proof}</p>}
                <a
                  class="band-btn project-card__cta"
                  href={link}
                  target="_blank"
                  rel="noreferrer"
                >
                  Open {title}
                  <Icon name="arrow-up-right" size={18} />
                </a>
              </div>

              <div class="viz-feature-art">
                <div
                  class="viz-sketch-pad"
                  style={`rotate: ${TILE_ROTATION[index % TILE_ROTATION.length]}deg`}
                >
                  <canvas
                    class="sketch-canvas"
                    data-sketch="project"
                    data-project={id}
                    width="560"
                    height="320"
                    aria-hidden="true"
                  />
                </div>
              </div>
            </div>
          </li>
        );
      })
    }
  </ul>

  <div class="project-more">
    <h3 class="project-more__heading">More from the workbench.</h3>
    <ul class="project-mini-grid">
      {
        rest.map(({ title, description, tech, link }, index) => {
          const accent = MINI_ACCENT[index % MINI_ACCENT.length];
          return (
            <li class="project-mini" style={`--card-accent:${accent}`}>
              <a
                class="project-mini__link"
                href={link}
                target="_blank"
                rel="noreferrer"
              >
                <span class="project-mini__title">
                  {title}
                  <Icon name="arrow-up-right" size={17} />
                </span>
                <span class="project-mini__desc">{description}</span>
                <span class="project-mini__tags">
                  {tech.map((t) => (
                    <span class="project-tag">{t}</span>
                  ))}
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
