---
import { Mail, Newspaper, Shapes } from '@lucide/astro';
---

<footer class="border-t border-black/5">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div
      class="grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-4 md:grid-cols-[9fr_5fr_5fr_5fr] md:gap-x-10"
    >
      <div class="col-span-2 sm:col-span-4 md:col-span-1">
        <a
          class="inline-flex items-center gap-2 no-underline"
          href="/"
          aria-label="AOUOS"
        >
          <img src="/logo.svg" alt="" width="26" height="26" />
          <span
            class="font-canvas text-[1.25rem] font-semibold text-[var(--ink)] transition-colors hover:text-[#2563eb]"
          >
            AOUOS
          </span>
        </a>
        <p class="mt-3 text-sm leading-6 text-[rgba(74,65,56,0.65)]">
          Bolt Guo's projects, notes, and small product experiments.
        </p>
        <div class="mt-5 flex items-center gap-4">
          <a
            class="inline-flex items-center justify-center text-[var(--ink)] transition-colors hover:text-[#2563eb]"
            href="https://github.com/boltguo"
            target="_blank"
            rel="noreferrer"
            aria-label="GitHub"
          >
            <svg
              class="h-[18px] w-[18px]"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.595 24 12.297c0-6.627-5.373-12-12-12"
              ></path>
            </svg>
          </a>
          <a
            class="inline-flex items-center justify-center text-[var(--ink)] transition-colors hover:text-[#2563eb]"
            href="mailto:hello@aouos.com"
            aria-label="Email"
          >
            <Mail size={18} strokeWidth={2} />
          </a>
        </div>
      </div>

      <div class="flex flex-col gap-3">
        <span
          class="text-[11px] font-semibold text-[rgba(74,65,56,0.62)] uppercase"
        >
          Product
        </span>
        <a
          class="inline-flex items-center gap-2.5 text-sm text-[var(--ink)] no-underline transition-colors hover:text-[#2563eb]"
          href="/projects"
        >
          <Shapes size={16} strokeWidth={2} aria-hidden="true" />
          Projects
        </a>
        <a
          class="inline-flex items-center gap-2.5 text-sm text-[var(--ink)] no-underline transition-colors hover:text-[#2563eb]"
          href="/blog"
        >
          <Newspaper size={16} strokeWidth={2} aria-hidden="true" />
          Blog
        </a>
      </div>

      <div class="flex flex-col gap-3">
        <span
          class="text-[11px] font-semibold text-[rgba(74,65,56,0.62)] uppercase"
        >
          Work
        </span>
        <a
          class="text-sm text-[var(--ink)] no-underline transition-colors hover:text-[#2563eb]"
          href="https://vizlearn.app/"
          target="_blank"
          rel="noreferrer"
        >
          VizLearn
        </a>
        <a
          class="text-sm text-[var(--ink)] no-underline transition-colors hover:text-[#2563eb]"
          href="https://aouoai.com/"
          target="_blank"
          rel="noreferrer"
        >
          AouoAI
        </a>
        <a
          class="text-sm text-[var(--ink)] no-underline transition-colors hover:text-[#2563eb]"
          href="https://wmremover.aouos.com/"
          target="_blank"
          rel="noreferrer"
        >
          Watermark Remover
        </a>
      </div>

      <div class="flex flex-col gap-3">
        <span
          class="text-[11px] font-semibold text-[rgba(74,65,56,0.62)] uppercase"
        >
          Connect
        </span>
        <a
          class="text-sm text-[var(--ink)] no-underline transition-colors hover:text-[#2563eb]"
          href="mailto:hello@aouos.com"
        >
          hello@aouos.com
        </a>
      </div>
    </div>
  </div>
</footer>
